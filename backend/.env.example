# 服务器配置
PORT=3000
NODE_ENV=development
HOST=0.0.0.0

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=car_navigation

# JWT配置
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 地图API配置（可选）
AMAP_KEY=your_amap_api_key
BAIDU_MAP_KEY=your_baidu_map_key
